{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "datasource", "uid": "grafana"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Roost — queue throughput, latency, and failure overview. Pair with the Prometheus extras: pip install roost[metrics].",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "GitHub",
      "url": "https://github.com/ashhadahsan/roost",
      "type": "link",
      "icon": "external link",
      "targetBlank": true
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Enqueued / sec",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(roost_jobs_enqueued_total[1m]))",
          "legendFormat": "enqueue/s",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {"unit": "ops", "decimals": 1, "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "blue", "value": null}
          ]}
        }
      }
    },
    {
      "id": 2,
      "title": "Completed / sec",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(roost_jobs_completed_total[1m]))",
          "legendFormat": "complete/s",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {"unit": "ops", "decimals": 1, "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null}
          ]}
        }
      }
    },
    {
      "id": 3,
      "title": "Discarded (terminal failures) / 5m",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "sum(increase(roost_jobs_failed_total{outcome=\"discarded\"}[5m]))",
          "legendFormat": "discarded",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {"unit": "short", "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 1},
            {"color": "red", "value": 10}
          ]}
        }
      }
    },
    {
      "id": 4,
      "title": "p50 / p95 / p99 handler duration",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(roost_job_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(roost_job_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(roost_job_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "graphMode": "none",
        "colorMode": "none"
      },
      "fieldConfig": {"defaults": {"unit": "s", "decimals": 3}}
    },
    {
      "id": 10,
      "title": "Throughput by task",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {
          "expr": "sum by (task) (rate(roost_jobs_completed_total[1m]))",
          "legendFormat": "{{task}}",
          "refId": "A"
        }
      ],
      "options": {"legend": {"showLegend": true, "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 8, "stacking": {"mode": "normal"}}}}
    },
    {
      "id": 11,
      "title": "Failure rate by outcome",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {
          "expr": "sum by (outcome) (rate(roost_jobs_failed_total[1m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "options": {"legend": {"showLegend": true, "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 8}}}
    },
    {
      "id": 20,
      "title": "Handler duration heatmap",
      "type": "heatmap",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "targets": [
        {
          "expr": "sum by (le) (rate(roost_job_duration_seconds_bucket[1m]))",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ],
      "options": {"calculate": false, "yAxis": {"unit": "s", "decimals": 2}}
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["roost", "queue", "postgres"],
  "templating": {
    "list": [
      {
        "current": {"text": "Prometheus", "value": "prometheus"},
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "label": "Prometheus"
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "Roost — overview",
  "uid": "roost-overview",
  "version": 1,
  "weekStart": ""
}
